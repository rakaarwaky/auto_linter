# ==============================================================================
# Auto-Linter Configuration Example (YAML)
# ==============================================================================
# This file defines the quality rules and architectural governance of your project.
# Save as 'auto_linter.config.yaml' in your project root.

# ------------------------------------------------------------------------------
# 1. Thresholds
# ------------------------------------------------------------------------------
thresholds:
  # Minimum score for 'passing' status to be True (0.0 - 100.0)
  score: 85.0
  
  # Maximum cyclomatic complexity per function (Radon)
  complexity: 12
  
  # Maximum line count per file before it's considered an SRP violation
  max_file_lines: 500

# ------------------------------------------------------------------------------
# 2. Adapter Configuration
# ------------------------------------------------------------------------------
# You can set weights for each linter.
# The final score is calculated based on point deductions multiplied by this weight.
adapters:
  - name: ruff
    weight: 1.0
  - name: mypy
    weight: 1.0
  - name: bandit
    weight: 1.5  # Security issues have higher weights
  - name: radon
    weight: 1.0
  - name: pip-audit
    weight: 2.0  # Library vulnerabilities are critical
  - name: governance
    weight: 2.5  # Architectural violations are the most fatal

# ------------------------------------------------------------------------------
# 3. Layer Map (Architecture Mapping)
# ------------------------------------------------------------------------------
# Define layer names and their folder locations.
# These layer names will be used in the 'governance_rules' section.
layer_map:
  surfaces: src/surfaces      # Input/Output (CLI, MCP, Web)
  capabilities: src/capabilities # Business Logic / Use Cases
  agent: src/agent            # Orchestration / DI Container
  taxonomy: src/taxonomy      # Data models, Interfaces, Constants
  infrastructure: src/infrastructure # External libraries, Database, File System

# ------------------------------------------------------------------------------
# 4. Governance Rules (Import Prohibition Rules)
# ------------------------------------------------------------------------------
# Use these rules to keep the architecture from becoming 'spaghetti'.
governance_rules:
  # Example: Prevent UI/CLI from calling the database directly
  - from: surfaces
    to: infrastructure
    description: "Surface layer must not import Infrastructure directly. Use Capabilities instead."

  # Example: Prevent business logic from depending on specific technical libraries
  - from: capabilities
    to: infrastructure
    description: "Capabilities layer must be independent of Infrastructure technical details."

  # Example: Ensure Taxonomy remains pure (has no other dependencies)
  - from: taxonomy
    to: agent
    description: "Taxonomy must be pure and must not import from the Agent layer."

  # Example: Prevent circular dependencies
  - from: infrastructure
    to: surfaces
    description: "Infrastructure is strictly forbidden from depending on Surface implementations."

# ------------------------------------------------------------------------------
# 5. Ignored Paths (Optional)
# ------------------------------------------------------------------------------
# List of folders to be ignored by the linter.
ignored_paths:
  - "**/node_modules/**"
  - "**/.venv/**"
  - "**/dist/**"
  - "**/build/**"
  - "**/tests/**"

