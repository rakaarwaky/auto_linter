# Auto-Linter Environment Configuration
# Copy to .env and customize. Works WITHOUT DesktopCommander out of the box.

# -- DesktopCommander Transport ------------------------------------
# Default: auto (tries socket -> http -> stdio fallback)
# Works without DesktopCommander — falls back to direct subprocess.
#
# To use DesktopCommander, uncomment one:
# DESKTOP_COMMANDER_URL=/tmp/dc.sock                          # Unix socket
# DESKTOP_COMMANDER_URL=http://localhost:24680/execute         # HTTP
# DESKTOP_COMMANDER_URL=stdio                                  # force stdio

# HTTP port (only if running http-wrapper):
DESKTOP_COMMANDER_PORT=24680

# Timeout in seconds:
DESKTOP_COMMANDER_TIMEOUT=300

# -- Path Normalization (Phantom Root) -----------------------------
# Root path for JavaScript/TypeScript linters.
PHANTOM_ROOT=$HOME/

# -- Config File Location ------------------------------------------
# AUTO_LINTER_CONFIG=auto_linter.config.yaml
